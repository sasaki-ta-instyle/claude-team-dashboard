# Anthropic Admin API key (https://console.anthropic.com/settings/admin-keys)
# Must be an admin key (starts with sk-ant-admin01-...).
ANTHROPIC_ADMIN_API_KEY=sk-ant-admin01-replace-me

# Password hash for the shared admin password (bcryptjs, rounds=10).
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
#
# IMPORTANT: Next.js (dotenv-expand) treats `$NAME` as a variable reference,
# which corrupts bcrypt hashes (they contain `$2a$10$...`). Escape each `$`
# with a backslash, e.g.:
#   ADMIN_PASSWORD_HASH=\$2a\$10\$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_PASSWORD_HASH=\$2a\$10\$replace-me

# JWT signing secret. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-32-byte-hex

# SQLite path. Local: ./data/data.sqlite. Production: /var/www/app/claude-team-dashboard/shared/data.sqlite
DATABASE_PATH=./data/data.sqlite

# How many days to look back on first sync (or full re-sync).
SYNC_LOOKBACK_DAYS=90

# Optional shared secret for the cron-triggered sync endpoint.
# If set, /api/sync requires header `X-Sync-Token: <value>`. Leave empty to allow only authenticated session.
SYNC_TOKEN=
